---
import '../../styles/global.css';
import { client, urlFor } from '../../utils/sanity.js';

export async function getStaticPaths() {
    const projects = await client.fetch(`*[_type == "project" && defined(slug.current)]{
        ...,
        "shortVideoUrl": shortVideo.asset->url
    }`);

    return projects.map((project: any) => {
        return {
            params: { slug: project.slug.current },
            props: { project }, 
        };
    });
}

const { project } = Astro.props as any; 

function getYouTubeId(url: string) {
    if(!url) return null;
    const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
    const match = url.match(regExp);
    return (match && match[2].length === 11) ? match[2] : null;
}
const ytId = getYouTubeId(project.videoUrl);
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{project.title} — Studio A4</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
    
    <style>
        .project-hero { position: relative; width: 100%; height: 70vh; min-height: 500px; overflow: hidden; display: flex; align-items: flex-end; padding: 80px 60px; background: var(--bg-primary); }
        .project-hero-media { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: top center; z-index: 0; }
        .project-hero::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(13,13,13,0.8) 0%, rgba(13,13,13,0.1) 20%, rgba(13,13,13,0.3) 60%, #0d0d0d 100%); z-index: 1; }
        .project-hero-content { position: relative; z-index: 2; max-width: 900px; width: 100%; }
        
        .project-details { padding: 100px 60px; max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: 1fr 2fr; gap: 80px; }
        
        /* MASONRY GALLERY */
        .project-gallery {
            padding: 0 60px 120px;
            max-width: 1400px;
            margin: 0 auto;
            column-count: 2;
            column-gap: 30px;
        }
        .gallery-img {
            width: 100%;
            margin-bottom: 30px;
            border-radius: var(--radius-lg);
            border: 1px solid var(--border-subtle);
            display: block;
            break-inside: avoid;
        }

        .cinematic-embed-wrapper { margin-top: 40px; width: 100%; aspect-ratio: 16 / 9; border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--border-subtle); background: #000; }
        .cinematic-embed-wrapper iframe { width: 100%; height: 100%; pointer-events: none; }

        @media (max-width: 768px) {
            .project-gallery { column-count: 1; }
            .project-details { grid-template-columns: 1fr; padding: 60px 20px; }
        }
    </style>
</head>
<body>
    <nav class="nav" style="background: transparent; border: none; backdrop-filter: none;">
        <a href="/" class="nav-logo">A<span>4</span></a>
    </nav>

    <header class="project-hero">
        {project.shortVideoUrl ? (
            <video src={project.shortVideoUrl} class="project-hero-media" autoplay muted loop playsinline></video>
        ) : project.mainImage ? (
            <img src={urlFor(project.mainImage).width(1920).url()} alt={project.title} class="project-hero-media" />
        ) : null}
        <div class="project-hero-content reveal">
            <a href="/#work" class="back-btn">← Back to Portfolio</a>
            <h1 class="hero-headline">{project.title}</h1>
        </div>
    </header>

    <section class="project-details">
        <div class="project-meta reveal reveal-d1">
            <h3>Role / Tag</h3> <p>{project.tag}</p>
            <h3>Category</h3> <p>{project.subtitle}</p>
        </div>
        <div class="project-info reveal reveal-d2">
            <div class="project-description">{project.description}</div>
            {ytId && (
                <div class="cinematic-embed-wrapper reveal reveal-d3">
                    <iframe src={`https://www.youtube.com/embed/${ytId}?autoplay=1&mute=1&loop=1&playlist=${ytId}&controls=0&modestbranding=1`} frameborder="0" allow="autoplay; fullscreen" allowfullscreen></iframe>
                </div>
            )}
        </div>
    </section>

    {project.gallery && project.gallery.length > 0 && (
        <section class="project-gallery">
            {project.gallery.map((image: any) => (
                <img src={urlFor(image).width(1200).url()} class="gallery-img reveal" loading="lazy" />
            ))}
        </section>
    )}

    <footer class="footer" style="text-align: center; padding: 60px 20px;">
        <h2 style="font-family: var(--font-display); font-size: 2.5rem; margin-bottom: 30px;">Ready to start your project?</h2>
        <a href="/#contact" class="btn btn-primary">Work With Us →</a>
    </footer>

    <script>
        const revealEls = document.querySelectorAll('.reveal');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
        }, { threshold: 0.1 });
        revealEls.forEach(el => observer.observe(el));
    </script>
</body>
</html>