---
import '../../styles/global.css';
import { client, urlFor } from '../../utils/sanity.js';

export async function getStaticPaths() {
    const projects = await client.fetch(`*[_type == "project" && defined(slug.current)]`);

    return projects.map((project: any) => {
        return {
            params: { slug: project.slug.current },
            props: { project }, 
        };
    });
}

const { project } = Astro.props as any; 
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{project.title} — Studio A4</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        .project-hero {
            position: relative;
            width: 100%;
            height: 70vh;
            min-height: 500px;
            overflow: hidden;
            display: flex;
            align-items: flex-end;
            padding: 80px 60px;
            background: var(--bg-primary);
        }
        .project-hero-img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center 15%; /* Better framing for character art */
            z-index: 0;
        }
        /* CINEMATIC FADE OVERLAY */
        .project-hero::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(
                to bottom, 
                rgba(13,13,13,0.8) 0%, /* Dark at top for logo */
                rgba(13,13,13,0.1) 20%, /* Clear in middle */
                rgba(13,13,13,0.3) 60%, 
                #0d0d0d 100% /* Solid dark at bottom to blend into page */
            );
            z-index: 1;
        }
        .project-hero-content {
            position: relative;
            z-index: 2;
            max-width: 900px;
            width: 100%;
        }
        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #fff;
            text-decoration: none;
            font-family: var(--font-body);
            font-weight: 600;
            margin-bottom: 30px;
            transition: var(--transition-fast);
            background: rgba(255, 255, 255, 0.1);
            padding: 10px 20px;
            border-radius: 50px;
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-subtle);
        }
        .back-btn:hover {
            background: rgba(255, 255, 255, 0.2);
            transform: translateX(-5px);
        }
        .project-details {
            padding: 100px 60px;
            max-width: 1280px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 80px;
        }
        .project-meta h3 {
            font-family: var(--font-display);
            color: var(--text-muted);
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 8px;
        }
        .project-meta p {
            color: var(--text-primary);
            font-size: 1.2rem;
            margin-bottom: 30px;
            font-weight: 500;
        }
        .project-description {
            font-size: 1.15rem;
            line-height: 1.8;
            color: var(--text-secondary);
            white-space: pre-wrap; 
        }
        .project-gallery {
            padding: 0 60px 120px;
            max-width: 1400px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
            gap: 30px;
        }
        .gallery-img {
            width: 100%;
            height: auto;
            border-radius: var(--radius-lg);
            border: 1px solid var(--border-subtle);
        }

        @media (max-width: 768px) {
            .project-hero { padding: 40px 20px; height: 50vh; }
            .project-details { grid-template-columns: 1fr; padding: 60px 20px; gap: 40px; }
            .project-gallery { grid-template-columns: 1fr; padding: 0 20px 80px; }
        }
    </style>
</head>
<body>

    <nav class="nav" style="background: transparent; border: none; backdrop-filter: none; -webkit-backdrop-filter: none;">
        <a href="/" class="nav-logo">A<span>4</span></a>
    </nav>

    <header class="project-hero">
        {project.mainImage && (
            <img src={urlFor(project.mainImage).width(1920).url()} alt={project.title} class="project-hero-img" />
        )}
        <div class="project-hero-content reveal">
            <a href="/#work" class="back-btn">← Back to Portfolio</a>
            <h1 class="hero-headline" style="margin-bottom: 10px;">{project.title}</h1>
        </div>
    </header>

    <section class="project-details">
        <div class="project-meta reveal reveal-d1">
            <h3>Role / Tag</h3>
            <p>{project.tag}</p>
            
            <h3>Client / Category</h3>
            <p>{project.subtitle}</p>
        </div>
        <div class="project-info reveal reveal-d2">
            <div class="project-description">
                {project.description || "In-depth case study and process details coming soon."}
            </div>
        </div>
    </section>

    {project.gallery && project.gallery.length > 0 && (
        <section class="project-gallery">
            {project.gallery.map((image: any, index: number) => (
                <img 
                    src={urlFor(image).width(1200).url()} 
                    alt={`Process Image ${index + 1}`} 
                    class={`gallery-img reveal reveal-d${(index % 3) + 1}`} 
                    loading="lazy"
                />
            ))}
        </section>
    )}

    <footer class="footer" style="text-align: center; padding: 60px 20px;">
        <h2 style="font-family: var(--font-display); font-size: 2.5rem; margin-bottom: 30px;">Ready to start your project?</h2>
        <a href="/#contact" class="btn btn-primary">Work With Us <span class="arrow-icon">→</span></a>
    </footer>

    <script>
        const revealEls = document.querySelectorAll('.reveal');
        if (revealEls.length > 0) {
            const revealObserver = new IntersectionObserver((entries: any[]) => {
                entries.forEach((entry: any) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                        revealObserver.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.05, rootMargin: '0px 0px -20px 0px' });
            revealEls.forEach((el: any) => revealObserver.observe(el));
        }
    </script>
</body>
</html>