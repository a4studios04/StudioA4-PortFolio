---
import '../../styles/global.css';
import { client, urlFor } from '../../utils/sanity.js';

export async function getStaticPaths() {
    const projects = await client.fetch(`*[_type == "project" && defined(slug.current)]{
        ...,
        "shortVideoUrl": shortVideo.asset->url
    }`);

    return projects.map((project: any) => {
        return {
            params: { slug: project.slug.current },
            props: { project }, 
        };
    });
}

const { project } = Astro.props as any; 

function getYouTubeId(url: string) {
    if(!url) return null;
    const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
    const match = url.match(regExp);
    return (match && match[2].length === 11) ? match[2] : null;
}
const ytId = getYouTubeId(project.videoUrl);

// Fallback to extract a secure poster image if video exists
const posterUrl = project.mainImage ? urlFor(project.mainImage).width(1920).url() : '';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{project.title} — Studio A4</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
    
    <style>
        /* HERO & BACK BUTTON RESTORED */
        .project-hero { position: relative; width: 100%; height: 70vh; min-height: 500px; overflow: hidden; display: flex; align-items: flex-end; padding: 80px 60px; background: var(--bg-primary); }
        .project-hero-media { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; z-index: 0; }
        .project-hero::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(13,13,13,0.8) 0%, rgba(13,13,13,0.1) 20%, rgba(13,13,13,0.3) 60%, #0d0d0d 100%); z-index: 1; pointer-events: none; }
        .project-hero-content { position: relative; z-index: 2; max-width: 900px; width: 100%; }
        
        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #fff;
            text-decoration: none;
            font-family: 'DM Sans', sans-serif;
            font-weight: 600;
            margin-bottom: 30px;
            transition: all 0.3s ease;
            background: rgba(255, 255, 255, 0.1);
            padding: 10px 20px;
            border-radius: 50px;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.1);
        }
        .back-btn:hover { background: rgba(255, 255, 255, 0.2); transform: translateX(-5px); }
        
        /* CONTENT & SOCIALS */
        .project-details { padding: 100px 60px; max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: 1fr 2fr; gap: 80px; }
        .project-meta h3 { font-family: 'Syne', sans-serif; color: rgba(255,255,255,0.5); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px; }
        .project-meta p { color: #fff; font-size: 1.2rem; margin-bottom: 30px; font-weight: 500; }
        .project-description { font-size: 1.15rem; line-height: 1.8; color: rgba(255,255,255,0.8); white-space: pre-wrap; margin-bottom: 40px; }
        
        .social-links { display: flex; gap: 15px; flex-wrap: wrap; margin-top: 20px; }
        .social-btn {
            padding: 8px 18px;
            background: rgba(255, 68, 68, 0.1);
            border: 1px solid rgba(255, 68, 68, 0.3);
            color: #ff4444;
            border-radius: 50px;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 600;
            transition: all 0.2s ease;
        }
        .social-btn:hover { background: #ff4444; color: #fff; transform: translateY(-2px); }

        /* MASONRY GALLERY */
        .project-gallery { padding: 0 60px 120px; max-width: 1400px; margin: 0 auto; column-count: 2; column-gap: 30px; }
        .gallery-img { width: 100%; margin-bottom: 30px; border-radius: 12px; display: block; break-inside: avoid; }

        /* VIDEO WRAPPER */
        .cinematic-embed-wrapper { margin-top: 40px; width: 100%; aspect-ratio: 16 / 9; border-radius: 12px; overflow: hidden; background: #000; }
        .cinematic-embed-wrapper iframe { width: 100%; height: 100%; pointer-events: none; }

        @media (max-width: 768px) {
            .project-hero { padding: 40px 20px; height: 50vh; }
            .project-details { grid-template-columns: 1fr; padding: 60px 20px; gap: 40px; }
            .project-gallery { column-count: 1; padding: 0 20px 80px; }
        }
    </style>
</head>
<body>
    <nav class="nav" style="background: transparent; border: none; backdrop-filter: none; -webkit-backdrop-filter: none;">
        <a href="/" class="nav-logo">A<span>4</span></a>
    </nav>

    <header class="project-hero">
        {/* Apple Standard: Poster image guarantees 0 black screens while video buffers */}
        {project.shortVideoUrl ? (
            <video 
                src={project.shortVideoUrl} 
                poster={posterUrl}
                class="project-hero-media" 
                autoplay muted loop playsinline 
            ></video>
        ) : project.mainImage ? (
            <img src={posterUrl} alt={project.title} class="project-hero-media" />
        ) : null}
        
        <div class="project-hero-content reveal">
            <a href="/#work" class="back-btn">← Back to Portfolio</a>
            <h1 style="font-family: 'Syne', sans-serif; font-size: clamp(3rem, 6vw, 6rem); line-height: 1; letter-spacing: -0.02em; font-weight: 800; color: #fff; margin: 0;">{project.title}</h1>
        </div>
    </header>

    <section class="project-details">
        <div class="project-meta reveal reveal-d1">
            <h3>Role / Tag</h3> <p>{project.tag}</p>
            <h3>Category</h3> <p>{project.subtitle}</p>
        </div>
        <div class="project-info reveal reveal-d2">
            <div class="project-description">{project.description || "In-depth case study and process details coming soon."}</div>
            
            {/* Render dynamically mapped Social Links from Sanity */}
            {project.socialLinks && project.socialLinks.length > 0 && (
                <div class="social-links">
                    {project.socialLinks.map((link: any) => (
                        <a href={link.url} target="_blank" rel="noopener noreferrer" class="social-btn">
                            View on {link.platform} ↗
                        </a>
                    ))}
                </div>
            )}

            {ytId && (
                <div class="cinematic-embed-wrapper reveal reveal-d3">
                    <iframe src={`https://www.youtube.com/embed/${ytId}?autoplay=1&mute=1&loop=1&playlist=${ytId}&controls=0&modestbranding=1`} frameborder="0" allow="autoplay; fullscreen" allowfullscreen></iframe>
                </div>
            )}
        </div>
    </section>

    {project.gallery && project.gallery.length > 0 && (
        <section class="project-gallery">
            {project.gallery.map((image: any, index: number) => (
                <img src={urlFor(image).width(1200).url()} class={`gallery-img reveal reveal-d${(index % 3) + 1}`} loading="lazy" />
            ))}
        </section>
    )}

    <footer class="footer" style="text-align: center; padding: 60px 20px;">
        <h2 style="font-family: 'Syne', sans-serif; font-size: 2.5rem; margin-bottom: 30px; color: #fff;">Ready to start your project?</h2>
        <a href="/#contact" style="display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 16px 32px; background: #ff4d4d; color: #fff; border-radius: 50px; text-decoration: none; font-family: 'DM Sans', sans-serif; font-weight: 600; font-size: 1.1rem; transition: background 0.3s ease;">
            Work With Us →
        </a>
    </footer>

    <script>
        const revealEls = document.querySelectorAll('.reveal');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
        }, { threshold: 0.1 });
        revealEls.forEach(el => observer.observe(el));
    </script>
</body>
</html>