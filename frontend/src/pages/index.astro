---
import '../styles/global.css';
import { client, urlFor } from '../utils/sanity.js';

// Fetch Projects
const projects = await client.fetch(`*[_type == "project"] | order(projectNumber asc)`);

// Fetch Testimonials sorted by the time they were created
const testimonials = await client.fetch(`*[_type == "testimonial"] | order(_createdAt desc)`);
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Studio A4 — Creative Design Studio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

    <nav class="nav" id="navbar">
        <a href="#" class="nav-logo">A<span>4</span></a>
        <ul class="nav-links">
            <li><a href="#work">Work</a></li>
            <li><a href="#services">Expertise</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
        <button class="nav-hamburger" id="hamburger" aria-label="Menu">
            <span></span><span></span><span></span>
        </button>
    </nav>

    <div class="mobile-menu" id="mobileMenu">
        <ul>
            <li><a href="#work" class="mobile-link">Work</a></li>
            <li><a href="#services" class="mobile-link">Expertise</a></li>
            <li><a href="#about" class="mobile-link">About</a></li>
            <li><a href="#contact" class="mobile-link">Contact</a></li>
        </ul>
    </div>

    <section class="hero" id="home">
        <div class="hero-bg">
            <div class="orb orb-1"></div>
            <div class="orb orb-2"></div>
        </div>
        <div class="hero-content">
            <span class="hero-tag">● Creative Studio — Est. 2020</span>
            <h1 class="hero-headline">
                We craft<br>
                <span class="italic">striking</span> digital<br>
                worlds.
            </h1>
            <p class="hero-description">
                A creative studio specializing in high-end 3D & 2D art, concept design, and visual development. We blend stylized aesthetics with compelling storytelling to build projects that leave a lasting impact.
            </p>
            <div class="hero-cta">
                <a href="#work" class="btn btn-primary">
                    View Our Work
                    <span class="arrow-icon">↘</span>
                </a>
                <a href="#contact" class="btn btn-outline">
                    Start a Project
                    <span class="arrow-icon">→</span>
                </a>
            </div>
        </div>
    </section>

    <div class="marquee-section">
        <div class="marquee-track">
            <span class="filled">Illustration</span> <span>✦</span> <span>Concept Art</span> <span>✦</span> <span class="filled">Character Design</span> <span>✦</span> <span>Background Art</span> <span>✦</span> <span class="filled">Visual Dev</span> <span>✦</span>
            <span class="filled">Illustration</span> <span>✦</span> <span>Concept Art</span> <span>✦</span> <span class="filled">Character Design</span> <span>✦</span> <span>Background Art</span> <span>✦</span> <span class="filled">Visual Dev</span> <span>✦</span>
        </div>
    </div>

    <section class="section" id="work">
        <div class="section-inner">
            <span class="section-label reveal">Selected Projects</span>
            <h2 class="section-title reveal reveal-d1">Recent work we're<br>proud of.</h2>
            <div class="work-grid">
                {projects.map((project: any, index: number) => (
                    <a href={`/project/${project.slug?.current}`} class={`work-item reveal reveal-d${(index % 4) + 1}`} style="display: block; text-decoration: none;">
                        <div class="work-item-inner">
                            {/* Logic to show video if it exists, else image */}
                            {project.shortVideo ? (
                                <video src={urlFor(project.shortVideo).url()} class="work-item-bg" muted loop playsinline autoplay />
                            ) : project.mainImage ? (
                                <img src={urlFor(project.mainImage).width(800).url()} alt={project.title} class="work-item-bg" loading="lazy" />
                            ) : <div class="work-item-bg" style="background:#111"></div>}
                            
                            <div class="work-item-overlay">
                                <span class="work-item-tag">{project.tag}</span>
                                <span class="work-item-title">{project.title}</span>
                                <span class="work-item-subtitle">{project.subtitle}</span>
                            </div>
                            <span class="work-item-number">{project.projectNumber}</span>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </section>

    <section class="section" id="services"> </section>
    <section class="section" id="about"> </section>
    <section class="section" style="background:var(--bg-secondary); overflow:hidden; padding: 100px 0;"> </section>
    <section class="section" id="contact"> </section>
    <footer class="footer"> </footer>

    <script>
        // MOBILE MENU
        const hamburger = document.getElementById('hamburger');
        const mobileMenu = document.getElementById('mobileMenu');
        const mobileLinks = document.querySelectorAll('.mobile-link');

        if (hamburger && mobileMenu) {
            hamburger.addEventListener('click', () => {
                hamburger?.classList.toggle('active');
                mobileMenu?.classList.toggle('active');
                document.body.style.overflow = mobileMenu?.classList.contains('active') ? 'hidden' : '';
            });
        }

        if (mobileLinks) {
            mobileLinks.forEach((link: any) => {
                link.addEventListener('click', () => {
                    hamburger?.classList.remove('active');
                    mobileMenu?.classList.remove('active');
                    document.body.style.overflow = '';
                });
            });
        }

        // INTERSECTION OBSERVER
        const revealEls = document.querySelectorAll('.reveal');
        if (revealEls.length > 0) {
            const revealObserver = new IntersectionObserver((entries: any[]) => {
                entries.forEach((entry: any) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                        revealObserver.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.01, rootMargin: '0px 0px -40px 0px' });
            revealEls.forEach((el: any) => revealObserver.observe(el));
        }

        // PARALLAX ORB
        const orb1 = document.querySelector('.orb-1') as HTMLElement | null;
        const orb2 = document.querySelector('.orb-2') as HTMLElement | null;
        document.addEventListener('mousemove', (e: MouseEvent) => {
            const x = (e.clientX - window.innerWidth / 2) / 60;
            const y = (e.clientY - window.innerHeight / 2) / 60;
            if (orb1) orb1.style.transform = `translate(${x * 18}px, ${y * 18}px)`;
            if (orb2) orb2.style.transform = `translate(${-x * 14}px, ${-y * 14}px)`;
        });

        // SCROLL SPY
        const sections = document.querySelectorAll('section[id]');
        const navLinksAll = document.querySelectorAll('.nav-links a');
        window.addEventListener('scroll', () => {
            let current = '';
            sections.forEach((section: any) => {
                const sectionTop = section.offsetTop - 120;
                if (window.scrollY >= sectionTop) current = section.getAttribute('id');
            });
            navLinksAll.forEach((link: any) => {
                link.style.color = link.getAttribute('href') === '#' + current ? '#ff4d4d' : '#fff';
            });
        });

        // FORM SUBMISSION
        const contactForm = document.getElementById('contactForm') as HTMLFormElement | null;
        const formSuccess = document.getElementById('formSuccess') as HTMLElement | null;
        if (contactForm && formSuccess) {
            contactForm.addEventListener('submit', function(e: Event) {
                e.preventDefault();
                const submitBtn = contactForm.querySelector('button[type="submit"]') as HTMLButtonElement | null;
                if (!submitBtn) return;
                const originalBtnText = submitBtn.innerHTML;
                submitBtn.innerHTML = 'Sending...';
                
                fetch('https://api.web3forms.com/submit', { method: 'POST', body: new FormData(contactForm) })
                .then(res => {
                    if (res.status === 200) {
                        contactForm.style.display = 'none';
                        formSuccess.style.display = 'block';
                    } else {
                        submitBtn.innerHTML = originalBtnText;
                        alert('Something went wrong.');
                    }
                });
            });
        }
    </script>
</body>
</html>